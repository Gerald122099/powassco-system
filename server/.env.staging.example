# ───────────────────────────────────────────────────────────────────
# POWASSCO server — STAGING / TEST environment template
#
# Copy this to .env.staging and fill in the real values BEFORE running
#   npm run dev:staging          (local dev against staging cluster)
#   npm run start:staging        (production-style run against staging)
#
# NEVER commit .env.staging — only this *.example template belongs in
# the repo. .gitignore already covers it.
#
# Every variable here MUST differ from the production .env so a leak
# from one environment can't move records / tokens / pushes in the
# other.
# ───────────────────────────────────────────────────────────────────

# Connect to the SEPARATE staging Atlas cluster (or a different DB
# name on the same cluster). Production reads PowasscoDB; pointing
# this at PowasscoDB_test on the same cluster works but a fully
# separate cluster gives you isolated IP allowlist + DB users.
MONGO_URI=mongodb+srv://<staging_user>:<password>@<staging-cluster>.mongodb.net/PowasscoDB_test?retryWrites=true&w=majority

# Different secret from production — otherwise a token minted on prod
# would still authenticate on staging and vice versa.
JWT_SECRET=<run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))">

# Comma-separated list of allowed browser origins for CORS. Match
# whatever you deploy the staging client to (Vercel preview URL,
# subdomain, etc.).
CLIENT_ORIGIN=https://staging.powassco.site,https://powassco-staging.vercel.app,http://localhost:5173

PORT=5000

# Web push — REGENERATE these with `npx web-push generate-vapid-keys`.
# Otherwise a staging "new reading" notification would deliver to the
# real subscribers stored in production.
VAPID_PUBLIC_KEY=<regenerate>
VAPID_PRIVATE_KEY=<regenerate>
VAPID_SUBJECT=mailto:staging@powassco.site

# PayMongo / Xendit — USE SANDBOX KEYS. The prefix on PayMongo test
# keys is sk_test_/pk_test_; on Xendit the dashboard exposes a
# Test-Mode toggle. Webhooks against these keys are sandbox events
# only — never real money.
PAYMONGO_PUBLIC=pk_test_<...>
PAYMONGO_SECRET=sk_test_<...>
PAYMONGO_WEBHOOK_SECRET=<sandbox webhook secret>
XENDIT_SECRET=<sandbox key>
XENDIT_WEBHOOK_TOKEN=<sandbox webhook token>

# Marker that the client picks up and uses to label every page with
# "STAGING — test data". Anything truthy works; "staging" is the
# convention. The client compares strictly so leave it lowercase.
ENV_NAME=staging
