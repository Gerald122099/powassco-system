# ───────────────────────────────────────────────────────────────────
# POWASSCO client — STAGING / TEST environment template
#
# Copy this to .env.staging and point VITE_API_BASE at the staging
# Render service. Then:
#   npm run dev -- --mode staging      (local Vite against staging API)
#   npm run build:staging              (production build for staging)
#
# Vite picks up .env.staging automatically when launched with
# `--mode staging`, so no extra tooling is needed on the client side.
# ───────────────────────────────────────────────────────────────────

# Staging Render service URL.
VITE_API_BASE=https://powassco-system-staging.onrender.com/api

# Banner marker — when this is set to "staging" the client renders a
# big "STAGING — test data, not real members" ribbon at the top of
# every screen so testers can't confuse the two environments.
VITE_ENV=staging
